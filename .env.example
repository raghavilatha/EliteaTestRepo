# EliteA Pipeline - Environment Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env file to version control

# ============================================
# GITHUB CONFIGURATION
# ============================================
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_your_token_here

# ============================================
# CONFLUENCE CONFIGURATION
# ============================================
# Base URL of your Confluence instance
CONFLUENCE_URL=https://your-company.atlassian.net

# Your email address or username
CONFLUENCE_USERNAME=your-email@company.com

# API Token from: Confluence Settings → API Tokens → Create API Token
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# Default space key for creating pages (can be overridden via CLI)
CONFLUENCE_SPACE=DOC

# ============================================
# CLAUDE API CONFIGURATION
# ============================================
# Get key from: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=sk-ant-your_key_here

# Claude model to use for extraction
# Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
CLAUDE_MODEL=claude-3-sonnet-20240229

# Maximum tokens for Claude API responses
CLAUDE_MAX_TOKENS=2048

# ============================================
# PIPELINE CONFIGURATION
# ============================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable verbose logging output
VERBOSE=false

# Default template to use for extraction
DEFAULT_TEMPLATE=Technical-App-Manifest-v1

# Number of retries for API failures
MAX_RETRIES=3

# Timeout for API requests (seconds)
API_TIMEOUT=30

# ============================================
# EXECUTION OPTIONS
# ============================================
# Dry run mode (test without creating Confluence pages)
DRY_RUN=false

# Auto-update existing pages (if false, will create new page)
AUTO_UPDATE=false

# Save output to file (useful for review before publishing)
# Leave empty to skip file output
OUTPUT_FILE=

# ============================================
# ADVANCED OPTIONS
# ============================================
# Use proxy for API requests (optional)
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080

# AWS Secrets Manager support (optional)
# Use AWS credentials instead of environment variables
USE_AWS_SECRETS=false

# AWS region if using Secrets Manager
AWS_REGION=us-east-1

# ============================================
# NOTIFICATIONS (OPTIONAL)
# ============================================
# Send Slack notification on completion
SLACK_WEBHOOK_URL=

# Send email notification
SEND_EMAIL_ON_COMPLETION=false
EMAIL_RECIPIENT=your-email@company.com

# ============================================
# FEATURE FLAGS
# ============================================
# Enable strict fact mode (don't infer missing data)
STRICT_FACT_MODE=true

# Preserve manual sections when updating pages
PRESERVE_MANUAL_SECTIONS=true

# Cache extracted data (useful for testing)
ENABLE_CACHE=false

# Validate all extracted data before publishing
VALIDATE_BEFORE_PUBLISH=true
